{
  "name": "finalruntestspec",
  "version": "1.0.0",
  "description": "An artifact-driven CLI for generating plain-English YAML UI tests.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "frtestspec": "./bin/frtestspec.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node ./bin/frtestspec.js",
    "test": "npm run build && node --test test/workflow.test.mjs"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.5.0",
    "commander": "^14.0.0",
    "ora": "^8.2.0",
    "yaml": "^2.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "typescript": "^5.7.3"
  }
}
