{
  "name": "finalrun-agent-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for the finalrun-agent CLI",
  "workspaces": [
    "packages/common",
    "packages/device-node",
    "packages/goal-executor",
    "packages/cli",
    "packages/report-web"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:drivers": "./scripts/build-drivers-android.sh && ./scripts/build-drivers-ios.sh",
    "build:drivers:android": "./scripts/build-drivers-android.sh",
    "build:drivers:ios": "./scripts/build-drivers-ios.sh",
    "clean": "rm -rf packages/*/dist packages/*/tsconfig.tsbuildinfo finalruntestspec/tsconfig.tsbuildinfo packages/report-web/.next drivers/android/.gradle drivers/android/.kotlin drivers/android/app/build drivers/android/build drivers/ios/.derived-data resources/android/*.apk resources/ios/*.zip resources/ios/Debug-iphonesimulator",
    "dev:cli": "npm run dev --workspace=packages/cli --",
    "dev:report": "npm run dev --workspace=packages/report-web --",
    "dev:watch": "tsc --build --watch --preserveWatchOutput packages/common/tsconfig.json packages/device-node/tsconfig.json packages/goal-executor/tsconfig.json packages/cli/tsconfig.json",
    "lint": "eslint packages/*/src packages/cli/bin packages/cli/scripts finalruntestspec/src finalruntestspec/test finalruntestspec/bin eslint.config.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run build && npm run test:workspaces",
    "test:workspaces": "npm run test --workspaces --if-present",
    "generate:proto": "npm run generate:proto --workspace=packages/device-node"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.2"
  }
}
