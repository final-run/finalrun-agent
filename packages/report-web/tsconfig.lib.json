{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "composite": false,
    "declaration": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "jsx": "react-jsx",
    "ignoreDeprecations": "5.0"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", ".next", "dist", "**/*.test.ts"]
}
